#include <stdio.h>

// 1. Onefun: 반환값 없음, 2단부터 9단까지 출력 (for 문 이용)
void Onefun() {
    printf("--- Onefun (2단~9단 출력) ---\n");
    for (int i = 2; i <= 9; i++) {
        printf("=== %d단 ===\n", i);
        for (int j = 1; j <= 9; j++) {
            printf("%d x %d = %d\n", i, j, i * j);
        }
        printf("\n");
    }
}

// 2. Twofun: 매개변수 있고, 반환값 없음
// (a < b) a단부터 b단까지 출력, (a > b) b단부터 a단까지 출력
void Twofun(int a, int b) {
    printf("--- Twofun (%d단~%d단 출력) ---\n", a, b);
    int start = (a < b) ? a : b;
    int end = (a < b) ? b : a;

    for (int i = start; i <= end; i++) {
        printf("=== %d단 ===\n", i);
        for (int j = 1; j <= 9; j++) {
            printf("%d x %d = %d\n", i, j, i * j);
        }
        printf("\n");
    }
}

// 3. Threefun: 매개변수 있고, 실수값 반환 (call-by-value)
// 반환값: a / b
float Threefun(int a, int b) {
    return (float)a / b; // 정수 나눗셈 방지를 위해 형변환
}

// 4. Fourfun: 매개변수 있고, 실수값 반환 (call-by-reference / 포인터 연산)
// ※ main 함수의 Fourfun(&a, &b) 호출 형태에 맞춰 포인터(*)로 구현했습니다.
float Fourfun(int *a, int *b) {
    return (float)(*a) / (*b); // 주소가 가리키는 값(포인터 연산)을 이용한 나눗셈
}

int main(void) {
    int a = 5, b = 3;
    
    Onefun();
    
    Twofun(a, b);
    
    // call-by-value로 값 전달 (5 / 3 = 1.667)
    float f1 = Threefun(a, b);
    printf("Threefun result : %6.3f \n", f1);
    
    // call-by-reference로 주소 전달
    float f2 = Fourfun(&a, &b);
    printf("Fourfun result : %6.3f \n", f2);
    
    return 0;
}
